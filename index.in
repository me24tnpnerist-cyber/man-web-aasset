<style>
  @import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700&family=Roboto+Mono:wght@300;500&display=swap');

  .stark-container {
    width: 100%;
    max-width: 1000px;
    margin: 0 auto;
    background-color: #0a0505; 
    background-image: 
      linear-gradient(0deg, rgba(20, 0, 0, 0.8) 0%, rgba(10, 5, 5, 0.9) 100%),
      url('data:image/svg+xml;base64,');
    font-family: 'Roboto Mono', monospace;
    border: 2px solid #2a0a0a;
    box-shadow: 0 0 20px rgba(200, 16, 46, 0.2); 
    padding: 20px;
    box-sizing: border-box;
  }

  .stark-header {
    text-align: center;
    padding: 30px 20px;
    margin-bottom: 30px;
    border-bottom: 2px solid #fdb813; 
    position: relative;
  }

  .stark-header::before {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 50px;
    height: 10px;
    background: #0a0505;
    transform: skewX(45deg);
    border-right: 2px solid #fdb813;
  }

  .stark-header h2 {
    margin: 0;
    font-family: 'Orbitron', sans-serif;
    color: #ffffff;
    font-size: 28px;
    font-weight: bold;
    text-transform: uppercase;
    letter-spacing: 3px;
    text-shadow: 0 0 10px rgba(253, 184, 19, 0.6); 
  }
  
  .stark-header h2::before { content: "> "; color: #c8102e; }
  .stark-header h2::after { content: " <"; color: #c8102e; }

  .stark-row {
    display: flex;
    align-items: center;
    padding: 25px;
    background: rgba(30, 5, 5, 0.6); 
    margin-bottom: 15px;
    border: 1px solid #4a1010; 
    clip-path: polygon(0 0, 97% 0, 100% 15%, 100% 100%, 3% 100%, 0 85%);
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .stark-row:hover {
    background: rgba(60, 10, 15, 0.7); 
    border-color: #fdb813; 
    transform: translateY(-2px);
    box-shadow: 0 0 15px rgba(253, 184, 19, 0.2);
  }
  
  .stark-row::after {
    content: '';
    position: absolute;
    top: -100%;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(transparent, rgba(253, 184, 19, 0.15), transparent);
    transition: none;
  }
  
  .stark-row:hover::after {
    top: 100%;
    transition: top 1s linear;
  }

  .stark-image {
    flex-shrink: 0;
    width: 150px;
    height: 180px;
    margin-right: 40px;
    border: 2px solid #4a1010;
    position: relative;
    padding: 5px;
    background: #000;
  }

  .stark-image::before, .stark-image::after {
    content: '';
    position: absolute;
    width: 15px;
    height: 15px;
    border: 2px solid #fdb813;
    opacity: 0.5;
    transition: opacity 0.3s;
  }
  .stark-row:hover .stark-image::before, 
  .stark-row:hover .stark-image::after { opacity: 1; }

  .stark-image::before { top: -5px; left: -5px; border-right: none; border-bottom: none; }
  .stark-image::after { bottom: -5px; right: -5px; border-left: none; border-top: none; }

  .stark-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    filter: grayscale(10%) contrast(110%);
  }

  .stark-details {
    flex-grow: 1;
  }

  .stark-details h3 {
    font-family: 'Orbitron', sans-serif;
    font-size: 22px;
    margin: 0 0 10px 0;
    color: #ffffff;
    text-transform: uppercase;
    letter-spacing: 1.5px;
  }

  .stark-role {
    font-size: 14px;
    color: #fdb813; 
    margin: 0 0 15px 0;
    font-weight: 500;
    text-transform: uppercase;
    text-shadow: 0 0 8px rgba(200, 16, 46, 0.8); 
  }
  
  .stark-data {
    font-size: 13px;
    color: #a0a0a0;
    margin: 6px 0;
  }
  .stark-data span { color: #c8102e; font-weight: bold; }

  @media (max-width: 768px) {
    .stark-row {
      flex-direction: column;
      text-align: center;
      padding: 20px;
      clip-path: polygon(0 0, 100% 0, 100% 90%, 90% 100%, 0 100%, 0 10%);
    }
    
    .stark-image {
      margin-right: 0;
      margin-bottom: 20px;
      width: 120px;
      height: 150px;
    }
  }
</style>

